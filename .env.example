# ─── Demo mode (default for Vercel preview / client demo) ─────────────────────
# Real auth: set both to false and configure DATABASE_URL + NEXTAUTH_* below.
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# ─── Production database & auth (only when DEMO_MODE=false) ───────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/rijschool"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
